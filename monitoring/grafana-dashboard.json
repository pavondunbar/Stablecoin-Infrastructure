{
  "title": "Stablecoin Infrastructure Dashboard",
  "uid": "stablecoin-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{service}} {{method}} {{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "p95 {{service}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "RTGS Settlements / min",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(business_events_total{event_type=\"rtgs_settlement_completed\"}[1m]) * 60"
        }
      ],
      "options": { "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Token Issuances / min",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(business_events_total{event_type=\"token_issued\"}[1m]) * 60"
        }
      ]
    },
    {
      "id": 5,
      "title": "FX Settlements / min",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(business_events_total{event_type=\"fx_settled\"}[1m]) * 60"
        }
      ]
    },
    {
      "id": 6,
      "title": "Compliance Alerts / min",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(business_events_total{event_type=\"compliance_alert\"}[1m]) * 60"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka Publish Rate by Topic",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(kafka_publish_total{result=\"ok\"}[1m])",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Kafka Publish Errors",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(kafka_publish_total{result=\"error\"}[1m])",
          "legendFormat": "{{service}} {{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red" } } }
    },
    {
      "id": 9,
      "title": "DB Transaction Commit vs Rollback",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(db_transaction_total[1m])",
          "legendFormat": "{{service}} {{result}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "HTTP Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{service}} {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange" } } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "query": "label_values(http_requests_total, service)",
        "label": "Service",
        "multi": true,
        "includeAll": true
      }
    ]
  }
}
